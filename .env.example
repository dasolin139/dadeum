# === 다듬(Dadeum) 환경 변수 ===

# [필수] 서비스를 실제로 켜려면 이 키 하나만 있으면 됩니다.
# Vercel AI Gateway API 키. https://vercel.com/dashboard → AI Gateway 에서 발급.
# 없으면 /api/rewrite 가 503 을 반환하고, UI 는 데모 예시 안내를 보여줍니다(앱은 죽지 않습니다).
AI_GATEWAY_API_KEY=

# [선택] 윤문에 사용할 모델. 미설정 시 anthropic/claude-sonnet-5 사용.
# AI Gateway 모델 문자열 형식(provider/model).
REWRITE_MODEL=anthropic/claude-sonnet-5

# [선택] 결제 체크아웃 URL. 설정하면 유료 CTA 클릭 시 이 주소로 바로 이동합니다.
# (Lemon Squeezy / Gumroad 등 실제 결제 링크를 코드 수정 없이 여기에 넣으세요.)
# 미설정 시 클릭은 /api/intent 로 관심(WTP) 신호로 기록되고 안내 모달이 뜹니다.
NEXT_PUBLIC_CHECKOUT_URL=

# [선택] 관심(intent) 이벤트를 전달할 웹훅 URL. 설정하면 이벤트를 이 주소로 POST 합니다.
# (Slack Incoming Webhook, Zapier Catch Hook 등)
INTENT_WEBHOOK_URL=
